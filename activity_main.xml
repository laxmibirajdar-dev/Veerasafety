<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:gravity="center_horizontal"
    android:orientation="horizontal"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"
        android:text="Veera Safety System"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="#E8F5E9"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Guardian Name"
            android:textColor="#2E7D32"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#2E7D32"
            android:hint="Enter Guardian Name"
            android:inputType="textPersonName"
            android:textColor="#000000"
            android:textColorHint="#88000000" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="#E8F5E9"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Guardian Mobile Number"
            android:textColor="#2E7D32"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#2E7D32"
            android:hint="Enter Guardian Mobile Number"
            android:inputType="phone"
            android:textColor="#000000"
            android:textColorHint="#88000000" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveContact"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:text="Save Emergency Contact"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:backgroundTint="#2196F3"
        app:cornerRadius="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="32dp"
        android:text="Connect to Hardware"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:backgroundTint="#6200EE"
        app:cornerRadius="8dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Not Connected"
        android:textColor="#000000"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSos"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:elevation="8dp"
        android:gravity="center"
        android:text="SOS"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="#D32F2F"
        app:cornerRadius="60dp" />

</LinearLayout>
